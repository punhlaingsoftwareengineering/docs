# Application name (page titles, branding fallbacks)
PUBLIC_APP_NAME="zarnihlawn docs"

# Drizzle
DATABASE_URL="postgres://user:password@host:port/db-name"

# Server
PORT=1026
HOST=0.0.0.0

# ---------------------------------------------------------------------------
# ORIGIN — required for Better Auth OAuth and CSRF protection.
# Must exactly match the URL users type in the browser (scheme + host + port).
# ---------------------------------------------------------------------------

# Local / direct access
# ORIGIN="http://localhost:1026"

# LAN or cloud VM
# ORIGIN="http://192.168.1.50:1026"

# Behind reverse proxy with TLS (nginx, Caddy, Traefik)
# ORIGIN="https://docs.example.com"
# PROTOCOL_HEADER=x-forwarded-proto
# HOST_HEADER=x-forwarded-host
# PORT_HEADER=x-forwarded-port

ORIGIN="http://localhost:1026"

# Dev with `pnpm dev --host` (LAN IP access):
# Email/password sign-in works from any host. GitHub OAuth uses one callback URL —
# set ORIGIN to the URL you use for GitHub login (usually localhost above), or
# temporarily change ORIGIN + GitHub callback when testing from a LAN IP.

# Better Auth
BETTER_AUTH_SECRET=""

# GitHub OAuth — callback URL must be ${ORIGIN}/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Gmail SMTP (admin invitation emails)
# Use a Google App Password — not your normal Gmail password.
# https://myaccount.google.com/apppasswords (requires 2-Step Verification)
# SMTP_USER="you@gmail.com"
# SMTP_PASS="xxxx xxxx xxxx xxxx"
# EMAIL_FROM="zarnihlawn docs <you@gmail.com>"
