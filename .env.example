# Application name (page titles, branding fallbacks)
PUBLIC_APP_NAME="zarnihlawn docs"

# CMS database (documents, categories, site settings — local Postgres)
DATABASE_URL="postgres://user:password@localhost:5432/docs"

# Shared portal auth database (user, session, account, verification)
AUTH_DATABASE_URL="postgres://user:password@localhost:5432/portal"
PORTAL_DATABASE_URL="postgres://user:password@localhost:5432/portal"

# Server
PORT=1026
HOST=0.0.0.0

# ---------------------------------------------------------------------------
# SSO — must match employee-portal and PHH-DRIVE
# Browse http://docs.local.test (via employee-portal Caddy), not localhost:1026
# ---------------------------------------------------------------------------

ORIGIN="http://docs.local.test"
PORTAL_ORIGIN="http://portal.local.test"
AUTH_COOKIE_DOMAIN=".local.test"

# Same secret as employee-portal
BETTER_AUTH_SECRET=""

# Session options — keep in sync with portal
AUTH_SESSION_EXPIRES_IN="7d"
AUTH_SESSION_UPDATE_AGE="30m"
AUTH_SESSION_COOKIE_CACHE_MAX_AGE="30m"
AUTH_SESSION_COOKIE_CACHE_ENABLED="true"
AUTH_SESSION_SECURE_COOKIES="false"

# PHH-DRIVE — documentation media uploads (server-side only; never expose key to browser)
# DRIVE_ORIGIN="http://drive.local.test"
# DRIVE_INTERNAL_ORIGIN="http://localhost:1025"
# DRIVE_TEAM_API_KEY="znltv_…"
# DRIVE_STORAGE_PROVIDER="local"

# Max request body for drive media uploads (installers, ZIPs, large PDFs). Docker default: 1000M
# BODY_SIZE_LIMIT=1000M

# Behind reverse proxy with TLS (nginx, Caddy, Traefik)
# PROTOCOL_HEADER=x-forwarded-proto
# HOST_HEADER=x-forwarded-host
# PORT_HEADER=x-forwarded-port
