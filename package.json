{
	"name": "docs",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@11.5.1",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"start": "node build/index.js",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "pnpm run test:unit -- --run && pnpm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"db:push": "drizzle-kit push",
		"db:ensure": "tsx scripts/ensure-cms-tables.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config auth.config.ts --output src/lib/server/db/auth.schema.ts --yes",
		"docker:up": "docker compose up --build",
		"docker:build:local": "docker build -t docs:latest .",
		"docker:build": "docker build -t ghcr.io/punhlaingsoftwareengineering/docs:latest .",
		"docker:push": "docker push ghcr.io/punhlaingsoftwareengineering/docs:latest"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@better-auth/utils": "0.3.0",
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.18.2",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-node": "next",
		"@sveltejs/kit": "next",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^22",
		"@types/nodemailer": "^8.0.1",
		"@types/pg": "^8.20.0",
		"@types/qrcode": "^1.5.6",
		"@types/sanitize-html": "^2.16.0",
		"@vitest/browser-playwright": "^4.1.8",
		"better-auth": "~1.4.21",
		"daisyui": "^5.5.23",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"mdsvex": "^0.12.7",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@codemirror/commands": "^6.10.3",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/language": "^6.12.3",
		"@codemirror/state": "^6.6.0",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.43.1",
		"@lucide/svelte": "^1.17.0",
		"codemirror": "^6.0.2",
		"marked": "^18.0.5",
		"nodemailer": "^9.0.1",
		"pg": "^8.22.0",
		"qrcode": "^1.5.4",
		"sanitize-html": "^2.17.0",
		"uuid": "^14.0.0",
		"zod": "^4.4.3"
	}
}
