#
# Placeholder env used during Docker image build.
# The app reads these at build time via `src/env.ts`, and Better Auth needs
# BETTER_AUTH_SECRET to be non-empty so `auth.ts` doesn't crash.
#

# Public name (used for page titles)
PUBLIC_APP_NAME="docs"

# CMS (local Postgres placeholder; db:push/connects at runtime)
DATABASE_URL="postgres://postgres:postgres@localhost:5432/db_docs"

# Portal Postgres placeholders for shared auth + permission checks
AUTH_DATABASE_URL="postgres://postgres:postgres@localhost:5432/portal"
PORTAL_DATABASE_URL="postgres://postgres:postgres@localhost:5432/portal"

# SSO URLs (placeholder; used to derive Better Auth baseURL)
ORIGIN="http://localhost:1026"
PORTAL_ORIGIN="http://localhost:1027"

# Shared cookie domain placeholder
AUTH_COOKIE_DOMAIN=".local.test"

# Must be non-empty for Better Auth config
BETTER_AUTH_SECRET="build-only-secret-change-me"

# Session options (must match portal in real deployments)
AUTH_SESSION_EXPIRES_IN="7d"
AUTH_SESSION_UPDATE_AGE="30m"
AUTH_SESSION_COOKIE_CACHE_MAX_AGE="30m"

# PHH-DRIVE (optional at build time; required at runtime for Upload to Drive)
DRIVE_ORIGIN="http://localhost:1025"
DRIVE_INTERNAL_ORIGIN="http://localhost:1025"
DRIVE_TEAM_API_KEY="build-only-drive-key"
DRIVE_STORAGE_PROVIDER="local"

